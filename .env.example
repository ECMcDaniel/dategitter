# Copy this file to .env and set paths for your machine.

# Path to your Google Cloud service account JSON on the host machine.
GOOGLE_KEY_HOST_PATH=C:\Users\YourName\keys\google_key.json

# Path to your photos folder on the host machine.
PHOTOS_DIR_HOST_PATH=C:\Users\YourName\Pictures

# The container always uses /photos for images and /app/google_key.json for credentials.